# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml itself is gitignored -- NEVER commit it.
#
# On Streamlit Community Cloud, you don't need this file at all: paste the
# same three keys into your app's Settings -> Secrets panel instead.

UPSTOX_API_KEY = "your-api-key-here"
UPSTOX_API_SECRET = "your-api-secret-here"

# Must exactly match the Redirect URI configured in your Upstox developer
# app. For local dev this is usually http://localhost:8501
# For Streamlit Cloud, use your deployed app URL, e.g.:
# https://your-app-name.streamlit.app
UPSTOX_REDIRECT_URI = "http://localhost:8501"
